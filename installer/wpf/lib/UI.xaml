<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Rei AutoParts — Instalador"
    Width="800" Height="550"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#0d2137"
    FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0891b2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#06b6d4"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="#64748b"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Title" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#f8fafc"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="Subtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0a1929">
            <Image x:Name="SidebarImage" Stretch="UniformToFill"/>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1" Margin="32,28">

            <!-- Panel 1: Prerequisites -->
            <Grid x:Name="PanelPrereqs" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Style="{StaticResource Title}" Text="Verificacao de Pre-requisitos"/>
                    <TextBlock Style="{StaticResource Subtitle}" Text="O instalador verificara se as dependencias estao instaladas"/>
                    <StackPanel>
                        <TextBlock x:Name="NodeStatus" Text="Verificando Node.js..." Foreground="#94a3b8" FontSize="14" Margin="0,8,0,0"/>
                        <TextBlock x:Name="GitStatus" Text="Verificando Git..." Foreground="#94a3b8" FontSize="14" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PythonStatus" Text="Verificando Python..." Foreground="#94a3b8" FontSize="14" Margin="0,8,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,20,0,0">
                        <Button x:Name="BtnInstallPrereqs" Content="Instalar Pre-requisitos" Style="{StaticResource BtnPrimary}" Visibility="Collapsed"/>
                        <ProgressBar x:Name="PrereqProgress" Height="4" Margin="0,12,0,0" IsIndeterminate="True" Visibility="Collapsed" Foreground="#06b6d4"/>
                        <TextBlock x:Name="PrereqProgressText" Foreground="#94a3b8" FontSize="12" Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="2" x:Name="BtnNext1" Content="Proximo" Style="{StaticResource BtnPrimary}" IsEnabled="False" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Panel 2: Token -->
            <Grid x:Name="PanelToken" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Style="{StaticResource Title}" Text="Token GitHub"/>
                    <TextBlock Style="{StaticResource Subtitle}" Text="Insira um Personal Access Token com permissao de leitura no repositorio"/>
                    <StackPanel>
                        <TextBlock Text="Token:" Foreground="#cbd5e1" FontSize="13" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="TokenInput" Height="36" FontSize="14" Background="#1e293b" Foreground="#f8fafc" BorderBrush="#334155" Padding="8,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="BtnValidateToken" Content="Validar Token" Style="{StaticResource BtnPrimary}"/>
                            <TextBlock x:Name="TokenFeedback" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="13"/>
                        </StackPanel>
                        <TextBlock Margin="0,16,0,0" FontSize="12" Foreground="#64748b">
                            <Run Text="Nao tem um token? "/><Hyperlink NavigateUri="https://github.com/settings/tokens" Foreground="#06b6d4"><Run Text="Criar token no GitHub"/></Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="2" x:Name="BtnNext2" Content="Proximo" Style="{StaticResource BtnPrimary}" IsEnabled="False" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Panel 3: Supabase -->
            <Grid x:Name="PanelSupabase" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Style="{StaticResource Title}" Text="Configuracao Supabase"/>
                    <TextBlock Style="{StaticResource Subtitle}" Text="Credenciais do banco de dados (armazenadas com seguranca no Windows)"/>
                    <StackPanel>
                        <TextBlock Text="URL do Supabase:" Foreground="#cbd5e1" FontSize="13" Margin="0,0,0,6"/>
                        <TextBox x:Name="SupabaseUrl" Height="36" FontSize="14" Background="#1e293b" Foreground="#f8fafc" BorderBrush="#334155" Padding="8,6"/>
                        <TextBlock Text="Anon Key:" Foreground="#cbd5e1" FontSize="13" Margin="0,16,0,6"/>
                        <PasswordBox x:Name="SupabaseAnon" Height="36" FontSize="14" Background="#1e293b" Foreground="#f8fafc" BorderBrush="#334155" Padding="8,6"/>
                        <TextBlock Text="Service Role Key:" Foreground="#cbd5e1" FontSize="13" Margin="0,16,0,6"/>
                        <PasswordBox x:Name="SupabaseService" Height="36" FontSize="14" Background="#1e293b" Foreground="#f8fafc" BorderBrush="#334155" Padding="8,6"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="2" x:Name="BtnNext3" Content="Instalar" Style="{StaticResource BtnPrimary}" IsEnabled="False" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Panel 4: Install -->
            <Grid x:Name="PanelInstall" Visibility="Collapsed">

                <!-- Progress sub-panel -->
                <Grid x:Name="PanelProgress" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource Title}" Text="Instalando..."/>
                        <TextBlock x:Name="InstallStepText" FontSize="14" Foreground="#94a3b8" Margin="0,0,0,12"/>
                        <ProgressBar x:Name="InstallProgress" Height="8" Minimum="0" Maximum="100" Value="0" Foreground="#06b6d4" Background="#1e293b"/>
                        <TextBox x:Name="InstallLog" Margin="0,16,0,0" Height="220" Background="#0a0a0a" Foreground="#4ade80" FontFamily="Consolas" FontSize="11" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" BorderBrush="#1e293b" Padding="8"/>
                    </StackPanel>
                </Grid>

                <!-- Done sub-panel -->
                <Grid x:Name="PanelDone" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Title}" Text="Instalacao Concluida!" Foreground="#4ade80"/>
                        <TextBlock FontSize="14" Foreground="#94a3b8" Text="O sistema foi instalado com sucesso em C:\ContagemReiAutoParts"/>
                        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                            <Button x:Name="BtnOpenSystem" Content="Abrir Sistema" Style="{StaticResource BtnPrimary}"/>
                            <Button x:Name="BtnClose" Content="Fechar" Margin="12,0,0,0" Background="#334155" Foreground="#e2e8f0" FontSize="14" FontWeight="SemiBold" Padding="20,10" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

            </Grid>

        </Grid>
    </Grid>
</Window>
